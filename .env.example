# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.

# ------------------------------------------------------------------
# Google Cloud
# ------------------------------------------------------------------
# Your GCP project ID (e.g. my-gcp-project-123)
GOOGLE_CLOUD_PROJECT_ID=gmail-automation-489014

# Pub/Sub topic name (without the projects/.../topics/ prefix)
PUBSUB_TOPIC_NAME=gmail-notifications

# Pub/Sub push subscription name
PUBSUB_SUBSCRIPTION_NAME=gmail-notifications-sub

# ------------------------------------------------------------------
# Gmail OAuth2
# ------------------------------------------------------------------
# Raw JSON content of the OAuth2 client secret file downloaded from GCP Console.
# Paste the entire contents of client_secret.json as a single-line string.
# On first startup this value is written to the database, after which it is
# no longer required (leave blank to rely on the database-stored value).
GMAIL_CLIENT_SECRET_JSON=

# Path where the generated OAuth2 token will be stored (local dev only)
GMAIL_TOKEN_FILE=token.json

# Gmail user ID ('me' = authenticated user, or a full email address)
GMAIL_USER_ID=me

# ------------------------------------------------------------------
# Security
# ------------------------------------------------------------------
# A random secret appended as ?token=... to the Pub/Sub push URL.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PUBSUB_VERIFICATION_TOKEN=GwazJgFdHR3EIIgMvLW4SQMFiZmv_jRttsbqQ4KVSBo

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# PostgreSQL — used to persist the OAuth token across restarts.
# In Docker this resolves to the postgres service; for local dev use localhost.
DATABASE_URL=postgresql://emailprocessor:emailprocessor@localhost:5432/emailprocessor

# Comma-separated Gmail label IDs to watch.
# INBOX = normal email; add custom label IDs for archived/filtered emails.
# Call GET /gmail/labels to discover all label IDs.
# Example with a custom label: GMAIL_WATCHED_LABELS=INBOX,Label_123456789
GMAIL_WATCHED_LABELS=INBOX

# Set to true when running locally without a public URL.
# The app will PULL messages from Pub/Sub instead of waiting for pushes.
# Requires a standard (pull) subscription to exist alongside the push one.
USE_PULL_SUBSCRIBER=false

# Public HTTPS base URL of this service.
# When set (and USE_PULL_SUBSCRIBER is false), the app registers the Pub/Sub
# push endpoint automatically at startup — no need to run configure_push.py.
# Example: PUBLIC_URL=https://emailprocess.berzuk.com
PUBLIC_URL=

# GCP service account key JSON for Pub/Sub push registration.
# Paste the full contents of the downloaded service account key file as a single-line string.
# The service account needs the "Pub/Sub Editor" role.
# Generate at: GCP Console → IAM & Admin → Service Accounts → Keys → Add Key → JSON
GCP_SERVICE_ACCOUNT_JSON=

