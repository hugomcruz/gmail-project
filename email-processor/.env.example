# Copy this file to .env and fill in your values.

# ------------------------------------------------------------------
# Database — PostgreSQL for rules storage
# ------------------------------------------------------------------
# In Docker Compose the hostname is the service name "postgres".
# For local dev outside Docker use localhost.
DATABASE_URL=postgresql://emailprocessor:emailprocessor@localhost:5432/emailprocessor

# ------------------------------------------------------------------
# App
# ------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Azure (Outlook inbound + OneDrive)
# ------------------------------------------------------------------
# Azure app Client ID used for Outlook inbound auth and OneDrive connections.
# Register your app at https://portal.azure.com → App registrations.
# Required scopes: Mail.Read (delegated) for Outlook, Files.ReadWrite (delegated) for OneDrive.
AZURE_CLIENT_ID=

# ------------------------------------------------------------------
# Outlook inbound webhooks (Microsoft Graph)
# ------------------------------------------------------------------
# Public HTTPS URL Graph will call with notifications.
# Example: https://your-domain.example/api/inbound-webhooks/outlook
OUTLOOK_WEBHOOK_NOTIFICATION_URL=

# Optional lifecycle callback URL. If blank, notification URL is reused.
OUTLOOK_WEBHOOK_LIFECYCLE_URL=

# Optional shared clientState secret used to validate webhook notifications.
# If left blank, a random per-connection value is generated and persisted.
OUTLOOK_WEBHOOK_CLIENT_STATE_SECRET=

# How often to renew existing Graph subscriptions in background.
OUTLOOK_WEBHOOK_RENEW_INTERVAL_SECONDS=600

# Renew subscriptions this many minutes before expiration.
OUTLOOK_WEBHOOK_RENEW_BEFORE_MINUTES=30
